# Copy to .env.local for local development (Create React App loads .env / .env.local)
# Get test keys from https://dashboard.stripe.com/apikeys

REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Canonical public site URL (no trailing slash) — used for SEO, Open Graph, and JSON-LD. Example: https://www.novashop.com
# REACT_APP_SITE_URL=https://www.example.com
