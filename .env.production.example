# Copy this file:  cp .env.production.example .env.production
# Then edit .env.production and run: npm run build
# (Never commit .env.production; it is gitignored.)

# Render API — required for Hostinger. No trailing slash.
# Example: https://nova-ecommerce-project-backend.onrender.com
REACT_APP_API_URL=https://nova-ecommerce-project-backend.onrender.com

# Your Hostinger site — https, no trailing slash (SEO / meta).
REACT_APP_SITE_URL=https://ebadahgroup.com

# Optional — use live key when you switch Stripe to live mode
# REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_...
